# ASP.NET Core environment
ASPNETCORE_ENVIRONMENT=Production

# Required production secrets.
# The PostgreSQL role must have CREATEDB if the target database may be missing on first startup.
ConnectionStrings__DefaultConnection=Host=127.0.0.1;Port=5432;Database=clothing_store;Username=store_user;Password=CHANGE_ME_STRONG_PASSWORD
AdminUser__Email=admin@your-domain.com
AdminUser__Password=CHANGE_ME_ADMIN_PASSWORD

# Optional YooMoney defaults. The same values can also be configured from the admin panel.
Integrations__YooMoney__Enabled=false
Integrations__YooMoney__WalletNumber=
Integrations__YooMoney__NotificationSecret=
Integrations__YooMoney__AccessToken=
Integrations__YooMoney__LabelPrefix=store
Integrations__YooMoney__PaymentTimeoutMinutes=30
Integrations__YooMoney__AllowBankCards=true
Integrations__YooMoney__AllowWallet=false

# Optional YooKassa defaults. Use your test shop credentials first, then switch to live credentials for production.
Integrations__YooKassa__Enabled=false
Integrations__YooKassa__ShopId=
Integrations__YooKassa__SecretKey=
Integrations__YooKassa__TestMode=true
Integrations__YooKassa__LabelPrefix=store
Integrations__YooKassa__PaymentTimeoutMinutes=60
Integrations__YooKassa__AllowBankCards=true
Integrations__YooKassa__AllowSbp=true
Integrations__YooKassa__AllowYooMoney=true

# Optional external auth defaults. They can also be duplicated in app settings from the admin panel.
Auth__Telegram__Enabled=false
Auth__Telegram__WidgetEnabled=false
Auth__Google__Enabled=false
Auth__Google__ClientId=
Auth__Google__ClientSecret=
Auth__Yandex__Enabled=false
Auth__Yandex__ClientId=
Auth__Yandex__ClientSecret=

# Optional database backup defaults. The admin panel can override schedule/retention,
# but the server should still provide a stable backup directory and pg_dump path.
# Linux example for pg_dump: /usr/bin/pg_dump
# Windows example for pg_dump: C:\Program Files\PostgreSQL\16\bin\pg_dump.exe
DatabaseBackup__PgDumpPath=
# Linux example for backup directory: /var/www/clothing_store/backups/database
# Windows example for backup directory: C:\clothing_store\backups\database
DatabaseBackup__Directory=
DatabaseBackup__Enabled=true
DatabaseBackup__ScheduleLocal=03:00,15:00
DatabaseBackup__RetentionDays=14
