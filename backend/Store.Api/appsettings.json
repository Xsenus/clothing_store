{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=127.0.0.1;Port=5432;Database=clothing_store;Username=store_user;Password=CHANGE_ME"
  },
  "AdminUser": {
    "Email": "",
    "Password": "",
    "Name": "System Admin"
  },
  "Cors": {
    "AllowAnyOrigin": false,
    "AllowedOrigins": [
      "http://localhost:5173",
      "https://localhost:5173",
      "http://localhost:3000",
      "https://localhost:3000",
      "http://127.0.0.1:5173",
      "https://127.0.0.1:5173"
    ]
  },
  "Swagger": {
    "Enabled": true
  },
  "DatabaseBackup": {
    "PgDumpPath": "",
    "Directory": "backend/backups/database",
    "Enabled": true,
    "ScheduleLocal": "03:00,15:00",
    "RetentionDays": 14
  },
  "DatabaseInitialization": {
    "SeedMode": "EnsureSeeded",
    "DefaultUser": {
      "Email": "",
      "Password": "",
      "Name": "Demo User"
    },
    "SeedTestData": false
  },
  "Jwt": {
    "Key": "YOUR_SUPER_SECRET_KEY_MIN_32_CHARACTERS_LONG_FOR_SECURITY",
    "Issuer": "ClothingStoreApi",
    "Audience": "ClothingStoreClient",
    "ExpiresDays": 7
  },
  "Security": {
    "PasswordHashIterations": 100000,
    "SessionTtlHours": 720,
    "AdminSessionTtlHours": 168,
    "RefreshSessionTtlHours": 2160,
    "SessionSlidingUpdateMinutes": 5
  },
  "Seed": {
    "ProductsPath": "seed/products.jsonl"
  },
  "Storage": {
    "UploadsDir": "backend/uploads",
    "MaxUploadFileSizeBytes": 20971520,
    "MaxFaviconUploadFileSizeBytes": 2097152
  },
  "Integrations": {
    "YooMoney": {
      "Enabled": false,
      "WalletNumber": "",
      "NotificationSecret": "",
      "AccessToken": "",
      "LabelPrefix": "store",
      "PaymentTimeoutMinutes": 30,
      "AllowBankCards": true,
      "AllowWallet": false
    },
    "YooKassa": {
      "Enabled": false,
      "ShopId": "",
      "SecretKey": "",
      "TestMode": true,
      "LabelPrefix": "store",
      "PaymentTimeoutMinutes": 60,
      "AllowBankCards": true,
      "AllowSbp": true,
      "AllowYooMoney": true
    },
    "YandexDelivery": {
      "UseTestEnvironment": false,
      "ApiToken": "",
      "SourceStationId": "",
      "PackageLengthCm": 30,
      "PackageHeightCm": 20,
      "PackageWidthCm": 10
    }
  }
}
