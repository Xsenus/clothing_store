{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Swagger": {
    "Enabled": false
  },
  "Security": {
    "PasswordHashIterations": 120000,
    "SessionTtlHours": 720,
    "AdminSessionTtlHours": 72,
    "RefreshSessionTtlHours": 720,
    "SessionSlidingUpdateMinutes": 5
  }
}
